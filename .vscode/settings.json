{
    // ---------------------------------------------------------------
    // Project-wide settings — safe to commit, apply to all contributors
    // ---------------------------------------------------------------

    // Clang-tidy analysis — always run against the native build
    "C_Cpp.codeAnalysis.clangTidy.enabled": true,
    "C_Cpp.codeAnalysis.runAutomatically": true,
    "C_Cpp.default.compileCommands": "${workspaceFolder}/build/native/compile_commands.json",

    // Exclude third-party and build artifacts from analysis
    "C_Cpp.codeAnalysis.exclude": {
        "**/external/**": true,
        "**/build/**": true,
        "**/_delete/**": true
    },

    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.fixAll": "always",
        "source.fixAll.clang-tidy": "always"
    },
    "editor.defaultFormatter": "xaver.clang-format", // optional: specify if using clang-format extension
    "[cpp]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },
    "workbench.colorCustomizations": {
        "editor.background": "#000000",
        "statusBar.background": "#300000",
        "sideBar.background": "#300000",
        "titleBar.activeBackground": "#300000"
    }
}